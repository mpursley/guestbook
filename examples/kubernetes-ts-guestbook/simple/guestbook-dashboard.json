          "refId": "A"
        },
        {
          "expr": "rate(container_network_transmit_bytes_total{namespace=\"default\", pod=~\"(frontend|redis).*\"}[1m])",
          "legendFormat": "{{pod}} (Out)",
          "refId": "B"
